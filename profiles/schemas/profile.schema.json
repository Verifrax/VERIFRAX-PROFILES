{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Verifrax/VERIFRAX-PROFILES/blob/main/profiles/schemas/profile.schema.json",
  "title": "VERIFRAX Profile",
  "type": "object",
  "required": ["id", "version", "target", "rules"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,64}$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "target": { "type": "string" },
    "rules": { "type": "array", "items": { "type": "object" } },
    "meta": { "type": "object" }
  },
  "additionalProperties": false
}
