{
  "type": "object",
  "required": ["id","version","scope","required_fields","rejection_codes","policy"],
  "additionalProperties": false,
  "properties": {
    "id": { "type":"string", "pattern":"^[a-z0-9][a-z0-9._-]*$" },
    "version": { "type":"string", "pattern":"^v[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "scope": { "type":"string", "minLength": 3 },
    "required_fields": { "type":"array", "minItems": 1, "items": { "type":"string" } },
    "rejection_codes": {
      "type":"array",
      "minItems": 1,
      "items": { "type":"string", "pattern":"^E_[A-Z0-9_]+$" }
    },
    "policy": { "type":"object" }
  }
}
